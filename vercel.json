{
  "version": 2,
  "installCommand": "npm install -g pnpm@9 && pnpm install --no-frozen-lockfile --config.minimumReleaseAge=0",
  "buildCommand": "pnpm run typecheck:libs && cd artifacts/chatme && npx vite build --config vite.vercel.config.ts",
  "outputDirectory": "artifacts/chatme/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
